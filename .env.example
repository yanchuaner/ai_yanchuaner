# PostgreSQL 用于保存 LiteLLM 用户、虚拟密钥、预算和用量记录。
POSTGRES_PASSWORD=请替换为仅含网址安全字符的随机密码
DATABASE_URL=postgresql://litellm:请替换为上方相同密码@db:5432/litellm

# 主密钥用于保护 LiteLLM 管理权限，值必须以 sk- 开头。
LITELLM_MASTER_KEY=sk-请替换为足够长的随机主密钥

# 盐值用于加密模型凭据，保存凭据后不得随意更换。
LITELLM_SALT_KEY=sk-请替换为足够长的随机盐值

# LiteLLM 管理界面独立登录，不应直接使用主密钥作为日常密码。
LITELLM_UI_USERNAME=yanchuaner
LITELLM_UI_PASSWORD=请运行scripts/reset-litellm-admin.ps1设置

# 只有配置模型渠道时才需要添加对应供应商凭据。
# OPENAI_API_KEY=
# GEMINI_API_KEY=

# 图片模型的 OpenAI 兼容上游地址。真实 API Key 由配置脚本隐藏输入，不写入本文件。
GPT_IMAGE_API_BASE_URL=https://api.openai.com/v1

# 冒烟测试使用受限虚拟密钥，禁止填写 LiteLLM 管理员主密钥。
LITELLM_BASE_URL=http://localhost:4000
LITELLM_TEST_KEY=sk-请填写仅用于开发测试的虚拟密钥
LITELLM_TEST_MODEL=请填写已接入并授权给测试密钥的模型名称

# 以下两个变量仅供历史 LiteLLM 直连 PoC 脚本使用，集成部署中的 Open WebUI 不读取它们。
OPENWEBUI_LITELLM_KEY=sk-请填写Open-WebUI专用虚拟密钥
OPENWEBUI_IMAGE_LITELLM_KEY=sk-请运行scripts/configure-gpt-image.ps1自动生成
# 集成部署通过燕中 API 的受限服务 Key 访问模型；当前只记入独立服务账户。
OPENWEBUI_API_KEY=sk-请由api_yanchuaner集成脚本生成
OPENWEBUI_IMAGE_API_KEY=sk-默认可与OPENWEBUI_API_KEY相同
API_GATEWAY_BASE_URL=http://api-gateway:3000/v1
AI_CORE_NETWORK=yanchuaner-ai-core
# Open WebUI 使用该密钥签名登录状态并加密敏感数据，部署后不得随意更换。
OPENWEBUI_SECRET_KEY=请替换为足够长的随机密钥
# 与网站同机部署时必须设为 3001，避免占用网站的 3000 端口。
OPENWEBUI_HOST_PORT=3001
OPENWEBUI_URL=http://localhost:3001
OPENWEBUI_CORS_ALLOW_ORIGIN=http://localhost:3001

# 主站是唯一身份源。本地注册保持关闭，认证校友首次登录时由 OAuth 自动建号。
YANCHUANER_AI_OAUTH_CLIENT_ID=ai-yanchuaner
YANCHUANER_AI_OAUTH_CLIENT_SECRET=请由api_yanchuaner集成脚本生成
YANCHUANER_AI_OAUTH_REDIRECT_URI=http://localhost:3001/oauth/oidc/callback
YANCHUANER_OIDC_DISCOVERY_URL=http://host.docker.internal:3000/api/oauth/.well-known/openid-configuration
OPENWEBUI_OAUTH_AUTO_REDIRECT=True

# 默认禁止注册。仅在全新实例创建首个管理员前临时改为 True。
OPENWEBUI_ENABLE_SIGNUP=False
